# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
*.tsbuildinfo

# Runtime data — generated by the pipeline (kept out of source control)
.cache/
output/
assets/
projects/
!assets/.gitkeep

# Secrets — NEVER commit real keys
.env
.env.local
.env.*.local

# Machine-specific npm cache mapping (written by the installer; absolute paths)
.npmrc

# Runtime data: usage counters, discovery review queue, IPC token (secret)
data/*
!data/.gitkeep
discovery-suggestions.json

# Remotion
remotion/out/
.remotion/

# Logs
*.log
npm-debug.log*
logs/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
