# ─────────────────────────────────────────────────────────────────────────────
# omnicinema-mcp — environment configuration
#
# Copy this file to `.env` and fill in ONLY the keys for services you actually
# use. Every credential below is YOUR OWN developer key for a service's official,
# documented API, used within that service's Terms of Service and rate limits.
#
# This project does NOT scrape web UIs, reuse browser session tokens, or bypass
# any paid tier. If a provider has no official API you can obtain a key for, it
# is intentionally not supported.
# ─────────────────────────────────────────────────────────────────────────────

# --- Where the pipeline stores everything (defaults to the repo root) ---------
# All caches, downloads, and rendered output stay under this directory.
CINEMA_ROOT=/Volumes/PortableSSD/omnicinema-mcp

# --- Stock footage / imagery (official free developer APIs) -------------------
# Pexels API key:   https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay API key:  https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# Unsplash Access Key: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# Freesound API key (stock SFX / ambience): https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=

# --- Generative video providers (bring-your-own-key, official APIs) -----------
# Hugging Face access token (Inference API / Inference Endpoints):
#   https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=
# Text-to-video model id on Hugging Face (leave blank to disable HF generation):
HF_VIDEO_MODEL=
# Text-to-image model on Hugging Face, e.g. black-forest-labs/FLUX.1-schnell:
HF_IMAGE_MODEL=
# Text-to-speech model on Hugging Face, e.g. hexgrad/Kokoro-82M or suno/bark:
HF_TTS_MODEL=
# Text-to-music model on Hugging Face, e.g. facebook/musicgen-small:
HF_MUSIC_MODEL=
# Replicate API token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Replicate text-to-video model, e.g. "owner/model" (leave blank to disable):
REPLICATE_VIDEO_MODEL=
# Replicate text-to-image model, e.g. "black-forest-labs/flux-schnell":
REPLICATE_IMAGE_MODEL=
# Replicate text-to-music model, e.g. "meta/musicgen":
REPLICATE_MUSIC_MODEL=
# fal.ai API key: https://fal.ai/dashboard/keys
FAL_API_KEY=
# fal.ai text-to-video model id, e.g. "fal-ai/ltx-video" (leave blank to disable):
FAL_VIDEO_MODEL=

# --- Optional: LLM used to enrich screenplays (bring-your-own-key) ------------
# If set, the script engine can call the Anthropic API to expand the deterministic
# screenplay scaffold into richer prose. If unset, the deterministic scaffold is
# used as-is (the pipeline works fully offline for planning).
ANTHROPIC_API_KEY=
# Model id to use when ANTHROPIC_API_KEY is set (see the claude-api docs).
ANTHROPIC_MODEL=claude-sonnet-5

# --- Optional: discovery (review-only) ----------------------------------------
# Raises the GitHub Search rate limit used by `discover_providers`. Optional.
#   https://github.com/settings/tokens (no scopes needed for public search)
GITHUB_TOKEN=

# --- Behavior toggles ---------------------------------------------------------
# Set to "1" to allow the transparent dependency installer to run install
# commands after interactive consent. Never installs silently.
CINEMA_ALLOW_INSTALL=0

# --- Inter-tool IPC server (localhost only) -----------------------------------
# Bind host — keep 127.0.0.1 unless you know what you are doing.
OMNICINEMA_IPC_HOST=127.0.0.1
OMNICINEMA_IPC_PORT=8787
# Optional fixed bearer token. If blank, a random token is generated and stored
# in data/ipc-token.txt (mode 0600).
OMNICINEMA_IPC_TOKEN=

# --- Free-tier quota overrides (Budget Guard) ---------------------------------
# Override any provider's daily/weekly/monthly guard rail. Format:
#   LIMIT_<PROVIDER>_<DAILY|WEEKLY|MONTHLY>=<integer>
# Example: raise Hugging Face's daily guard to 250 generations.
# LIMIT_HUGGINGFACE_DAILY=250
# LIMIT_REPLICATE_MONTHLY=1000
