{
  "name": "autonomous-cinema-mcp",
  "version": "0.1.0",
  "description": "A local Model Context Protocol (MCP) server that orchestrates an AI video-production pipeline: screenplay + shot continuity, legitimate stock/asset acquisition via official APIs, bring-your-own-key generative video providers, and Remotion-based auto-montage.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "autonomous-cinema-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "remotion",
    "skills",
    "tools-registry.json",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/pipeline.test.ts",
    "eval": "tsx --test test/pipeline.test.ts",
    "setup:render": "npm install --include=optional remotion react react-dom @remotion/cli @remotion/bundler @remotion/renderer",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video",
    "remotion",
    "ai-video",
    "screenplay",
    "montage",
    "pipeline",
    "claude"
  ],
  "author": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@remotion/bundler": "^4.0.486",
    "@remotion/cli": "^4.0.486",
    "@remotion/renderer": "^4.0.486",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.486"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
