{
  "name": "omnicinema-mcp",
  "version": "0.2.0",
  "description": "A local Model Context Protocol (MCP) server: a master asset-creation engine with a multi-agent persona consultation framework, image/vector design, voiceover + full music/genre synthesis, a video pipeline (screenplay continuity + Remotion montage), a free-tier budget guard, a localhost inter-tool REST API, and human-in-the-loop provider discovery — all via official APIs with your own keys.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "omnicinema-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "remotion",
    "skills",
    "tools-registry.json",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "eval": "tsx --test test/*.test.ts",
    "setup:render": "npm install --include=optional remotion react react-dom @remotion/cli @remotion/bundler @remotion/renderer",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video",
    "remotion",
    "ai-video",
    "image-generation",
    "vector",
    "svg",
    "text-to-speech",
    "music-generation",
    "midi",
    "personas",
    "screenplay",
    "montage",
    "pipeline",
    "claude"
  ],
  "author": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@remotion/bundler": "^4.0.486",
    "@remotion/cli": "^4.0.486",
    "@remotion/renderer": "^4.0.486",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.486"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
